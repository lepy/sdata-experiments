  skos:prefLabel "ISO 527-2/1b"@en ;
  stsp:profileClass "UTFlatType1" ;
  stsp:w "10.0"^^xsd:decimal ;
  stsp:t "4.0"^^xsd:decimal ;
  stsp:l0 "50.0"^^xsd:decimal ;
  stsp:W "20.0"^^xsd:decimal ;
  stsp:l2 "21.0208"^^xsd:decimal ;
  stsp:lg "17.5"^^xsd:decimal ;
  stsp:l1 "60.0"^^xsd:decimal ;
