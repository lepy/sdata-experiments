@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix stsp: <https://w3id.org/sdata/tensile/specimens/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/sdata/tensile/specimens/>
  a owl:Ontology ;
  rdfs:label "SData tensile specimen geometries"@en ;
  rdfs:comment "Controlled vocabulary for tensile specimen forms and standardized tensile specimen profiles."@en ;
  owl:imports <https://w3id.org/sdata/core> .

# ============================================================
# Concept schemes
# ============================================================

stsp:ConceptScheme a skos:ConceptScheme ;
  skos:prefLabel "Tensile specimen geometries"@en ;
  skos:prefLabel "Zugprobengeometrien"@de .

stsp:FlatTensileSpecimenProfiles a skos:ConceptScheme ;
  skos:prefLabel "Flat tensile specimen profiles"@en ;
  skos:prefLabel "Flachzugproben-Profile"@de .

# ============================================================
# Shape families
# ============================================================

stsp:flat a skos:Concept ;
  skos:inScheme stsp:ConceptScheme ;
  skos:prefLabel "flat tensile specimen"@en ;
  skos:prefLabel "Flachzugprobe"@de ;
  skos:altLabel "flat"@en .

stsp:round a skos:Concept ;
  skos:inScheme stsp:ConceptScheme ;
  skos:prefLabel "round tensile specimen"@en ;
  skos:prefLabel "Rundzugsprobe"@de ;
  skos:altLabel "round"@en .

stsp:tubular a skos:Concept ;
  skos:inScheme stsp:ConceptScheme ;
  skos:prefLabel "tubular tensile specimen"@en ;
  skos:prefLabel "Rohrzugprobe"@de ;
  skos:altLabel "tubular"@en .

stsp:hexa a skos:Concept ;
  skos:inScheme stsp:ConceptScheme ;
  skos:prefLabel "hexagonal tensile specimen"@en ;
  skos:prefLabel "Sechskantzugprobe"@de ;
  skos:altLabel "hexa"@en .

# ============================================================
# Geometric descriptor properties
# ============================================================

stsp:profileClass a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:string ;
  rdfs:label "profile class"@en .

stsp:w a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "parallel width w"@en .

stsp:t a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "thickness t"@en .

stsp:l0 a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "original gauge length l0"@en .

stsp:W a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "grip section width W"@en .

stsp:l2 a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "transition length l2"@en .

stsp:lg a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "grip length lg"@en .

stsp:l1 a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "parallel length l1"@en .

stsp:lt a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "total length lt"@en .

stsp:r a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "transition radius r"@en .

# ============================================================
# Standardized flat profile concepts
# ============================================================

stsp:din527_2_1a a skos:Concept ;
  skos:inScheme stsp:FlatTensileSpecimenProfiles ;
  skos:broader stsp:flat ;
  skos:notation "din527_2_1a" ;
  skos:prefLabel "ISO 527-2/1a"@en ;
  stsp:profileClass "UTFlatType1" ;
  stsp:w "10.0"^^xsd:decimal ;
  stsp:t "4.0"^^xsd:decimal ;
  stsp:l0 "75.0"^^xsd:decimal ;
  stsp:W "20.0"^^xsd:decimal ;
  stsp:l2 "30.337"^^xsd:decimal ;
  stsp:lg "27.5"^^xsd:decimal ;
  stsp:l1 "80.0"^^xsd:decimal ;
  stsp:lt "170.0"^^xsd:decimal ;
  stsp:r "24.0"^^xsd:decimal .

stsp:din527_2_1b a skos:Concept ;
  skos:inScheme stsp:FlatTensileSpecimenProfiles ;
  skos:broader stsp:flat ;
