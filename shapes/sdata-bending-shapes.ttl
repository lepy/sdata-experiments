@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sdt: <https://w3id.org/sdata/testdata/> .
@prefix sdb: <https://w3id.org/sdata/bending/> .
@prefix sq: <https://w3id.org/sdata/quantities/> .

<https://w3id.org/sdata/shapes/bending/>
  a owl:Ontology ;
  owl:imports <https://w3id.org/sdata/core/> ;
  owl:imports <https://w3id.org/sdata/quantities/> ;
  owl:imports <https://w3id.org/sdata/testdata/> ;
  owl:imports <https://w3id.org/sdata/bending/> .

sdb:BendingTestShape a sh:NodeShape ;
  sh:targetClass sdb:BendingTest ;
  sh:property [
    sh:path sdt:testId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sdt:hasSpecimen ;
    sh:class sdt:Specimen ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path sdt:usesMachine ;
    sh:class sdt:TestingMachine ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path sq:SupportSpanLength ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sdb:hasBendingResult ;
    sh:class sdb:BendingTestResult ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] .

sdb:BendingTestResultShape a sh:NodeShape ;
  sh:targetClass sdb:BendingTestResult ;
  sh:property [
    sh:path sq:FlexuralStrength ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:FlexuralModulus ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:MaximumDeflectionAtFailure ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:maxCount 1
  ] .
