@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sdata: <https://w3id.org/sdata/core/> .
@prefix sdt: <https://w3id.org/sdata/testdata/> .
@prefix sdb: <https://w3id.org/sdata/bending/> .
@prefix sq: <https://w3id.org/sdata/quantities/> .

<https://w3id.org/sdata/shapes/bending/>
  a owl:Ontology ;
  owl:imports <https://w3id.org/sdata/core> ;
  owl:imports <https://w3id.org/sdata/shapes/core/> ;
  owl:imports <https://w3id.org/sdata/quantities/> ;
  owl:imports <https://w3id.org/sdata/testdata/> ;
  owl:imports <https://w3id.org/sdata/bending/> .

# ============================================================
# BendingTestShape
# ============================================================

sdb:BendingTestShape a sh:NodeShape ;
  sh:targetClass sdb:BendingTest ;
  sh:property [
    sh:path sdt:testId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sdt:hasSpecimen ;
    sh:class sdt:Specimen ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path sdt:usesMachine ;
    sh:class sdt:TestingMachine ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path sdb:hasBendingResult ;
    sh:class sdb:BendingTestResult ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:SupportSpanLength ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:MandrelDiameter ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:InnerBendingRadius ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] .

# ============================================================
# BendingTestResultShape
# ============================================================

sdb:BendingTestResultShape a sh:NodeShape ;
  sh:targetClass sdb:BendingTestResult ;
  # --- Provenance (mandatory) ---
  sh:property [
    sh:path sdt:resultGenerationActivity ;
    sh:class sdt:ResultGenerationActivity ;
    sh:node sdt:ResultGenerationActivityShape ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sdt:resultGeneratedAt ;
    sh:datatype xsd:dateTime ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  # --- BendingAngle (mandatory -- central ISO 7438 parameter) ---
  sh:property [
    sh:path sq:BendingAngle ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  # --- Optional validated properties ---
  sh:property [
    sh:path sq:FlexuralStrength ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:FlexuralModulus ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:MaximumDeflectionAtFailure ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:BendingYieldStrength ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:BendingProofStress ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:MaximumBendingForce ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:ElasticDeflection ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:SpringBendingLimit ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] .
