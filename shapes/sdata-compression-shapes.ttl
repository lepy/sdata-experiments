@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sdata: <https://w3id.org/sdata/core/> .
@prefix sdt: <https://w3id.org/sdata/testdata/> .
@prefix sdc: <https://w3id.org/sdata/compression/> .
@prefix sq: <https://w3id.org/sdata/quantities/> .

<https://w3id.org/sdata/shapes/compression/>
  a owl:Ontology ;
  owl:imports <https://w3id.org/sdata/core/> ;
  owl:imports <https://w3id.org/sdata/shapes/core/> ;
  owl:imports <https://w3id.org/sdata/quantities/> ;
  owl:imports <https://w3id.org/sdata/testdata/> ;
  owl:imports <https://w3id.org/sdata/compression/> .

sdc:CompressionTestShape a sh:NodeShape ;
  sh:targetClass sdc:CompressionTest ;
  sh:property [
    sh:path sdt:hasSpecimen ;
    sh:class sdt:Specimen ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path sdt:usesMachine ;
    sh:class sdt:TestingMachine ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path sdc:hasCompressionResult ;
    sh:class sdc:CompressionTestResult ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] .

sdc:CompressionTestResultShape a sh:NodeShape ;
  sh:targetClass sdc:CompressionTestResult ;
  sh:property [
    sh:path sq:CompressiveStrength ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:CompressionModulus ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sq:StrainAtCompressiveStrength ;
    sh:class sdata:AttributeQuantityValue ;
    sh:node sdt:DecimalQuantityValueShape ;
    sh:maxCount 1
  ] .
