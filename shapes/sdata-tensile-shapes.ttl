@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sdt: <https://w3id.org/sdata/testdata/> .
@prefix sdn: <https://w3id.org/sdata/tensile/> .

<https://w3id.org/sdata/shapes/tensile/>
  a owl:Ontology ;
  owl:imports <https://w3id.org/sdata/testdata/> ;
  owl:imports <https://w3id.org/sdata/tensile/> .

sdn:TensileTestShape a sh:NodeShape ;
  sh:targetClass sdn:TensileTest ;
  sh:property [
    sh:path sdt:testId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sdt:hasSpecimen ;
    sh:class sdt:Specimen ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path sdt:usesMachine ;
    sh:class sdt:TestingMachine ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path sdn:hasTensileResult ;
    sh:class sdn:TensileTestResult ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] .

sdn:TensileTestResultShape a sh:NodeShape ;
  sh:targetClass sdn:TensileTestResult ;
  sh:property [
    sh:path sdn:Rm ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sdn:Rp ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sdn:A ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path sdn:Fm ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:maxCount 1
  ] .
