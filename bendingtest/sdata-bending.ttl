@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sdt: <https://w3id.org/sdata/testdata/> .
@prefix sdb: <https://w3id.org/sdata/bending/> .
@prefix sdata: <https://w3id.org/sdata/core/> .
@prefix sq: <https://w3id.org/sdata/quantities/> .

<https://w3id.org/sdata/bending/>
  a owl:Ontology ;
  rdfs:label "SData Bending"@en ;
  rdfs:comment "Bending-test specific extensions."@en ;
  owl:imports <https://w3id.org/sdata/core/> ;
  owl:imports <https://w3id.org/sdata/bending/specimens/> ;
  owl:imports <https://w3id.org/sdata/quantities/> ;
  owl:imports <https://w3id.org/sdata/testdata/> .

sdb:BendingTest a owl:Class ;
  rdfs:subClassOf sdt:QuasiStaticTest ;
  rdfs:label "Bending test"@en .

sdb:BendingTestResult a owl:Class ;
  rdfs:subClassOf sdt:TestResult ;
  rdfs:label "Bending test result"@en .

sdb:hasBendingResult a owl:ObjectProperty ;
  rdfs:domain sdb:BendingTest ;
  rdfs:range sdb:BendingTestResult ;
  rdfs:label "has bending result"@en .

sdb:FlexuralStrength a owl:ObjectProperty ;
  owl:equivalentProperty sq:FlexuralStrength ;
  rdfs:domain sdb:BendingTestResult ;
  rdfs:range sdata:AttributeQuantityValue ;
  rdfs:label "flexural strength"@en .

sdb:FlexuralModulus a owl:ObjectProperty ;
  owl:equivalentProperty sq:FlexuralModulus ;
  rdfs:domain sdb:BendingTestResult ;
  rdfs:range sdata:AttributeQuantityValue ;
  rdfs:label "flexural modulus"@en .

sdb:MaximumDeflectionAtFailure a owl:ObjectProperty ;
  owl:equivalentProperty sq:MaximumDeflectionAtFailure ;
  rdfs:domain sdb:BendingTestResult ;
  rdfs:range sdata:AttributeQuantityValue ;
  rdfs:label "maximum deflection at failure"@en .

sdb:SupportSpanLength a owl:ObjectProperty ;
  owl:equivalentProperty sq:SupportSpanLength ;
  rdfs:domain sdb:BendingTest ;
  rdfs:range sdata:AttributeQuantityValue ;
  rdfs:label "support span length"@en .
