# ============================================================
# EN 12384 Specimen Profiles (Cu-Federstreifen)
# ============================================================

sbsp:EN12384SpecimenProfiles a skos:ConceptScheme ;
  skos:prefLabel "EN 12384 spring strip specimen profiles"@en ;
  skos:prefLabel "Federstreifenproben nach EN 12384"@de .

sbsp:en12384_strip_005 a skos:Concept ;
  skos:inScheme sbsp:EN12384SpecimenProfiles ;
  skos:broader sbsp:stripSpecimen ;
  skos:notation "en12384_strip_005" ;
  skos:prefLabel "EN 12384 Strip t=0.05 mm"@en ;
  sbsp:profileClass "SpringStrip" ;
  sbsp:thickness "0.05"^^xsd:decimal ;
  sbsp:width "10.0"^^xsd:decimal ;
  sbsp:length "50.0"^^xsd:decimal .

sbsp:en12384_strip_010 a skos:Concept ;
  skos:inScheme sbsp:EN12384SpecimenProfiles ;
  skos:broader sbsp:stripSpecimen ;
  skos:notation "en12384_strip_010" ;
  skos:prefLabel "EN 12384 Strip t=0.10 mm"@en ;
  sbsp:profileClass "SpringStrip" ;
  sbsp:thickness "0.10"^^xsd:decimal ;
  sbsp:width "10.0"^^xsd:decimal ;
  sbsp:length "60.0"^^xsd:decimal .

sbsp:en12384_strip_020 a skos:Concept ;
  skos:inScheme sbsp:EN12384SpecimenProfiles ;
  skos:broader sbsp:stripSpecimen ;
  skos:notation "en12384_strip_020" ;
  skos:prefLabel "EN 12384 Strip t=0.20 mm"@en ;
  sbsp:profileClass "SpringStrip" ;
  sbsp:thickness "0.20"^^xsd:decimal ;
  sbsp:width "10.0"^^xsd:decimal ;
  sbsp:length "70.0"^^xsd:decimal .

sbsp:en12384_strip_050 a skos:Concept ;
  skos:inScheme sbsp:EN12384SpecimenProfiles ;
  skos:broader sbsp:stripSpecimen ;
  skos:notation "en12384_strip_050" ;
  skos:prefLabel "EN 12384 Strip t=0.50 mm"@en ;
  sbsp:profileClass "SpringStrip" ;
  sbsp:thickness "0.50"^^xsd:decimal ;
  sbsp:width "10.0"^^xsd:decimal ;
  sbsp:length "150.0"^^xsd:decimal .

sbsp:en12384_strip_100 a skos:Concept ;
  skos:inScheme sbsp:EN12384SpecimenProfiles ;
  skos:broader sbsp:stripSpecimen ;
  skos:notation "en12384_strip_100" ;
  skos:prefLabel "EN 12384 Strip t=1.00 mm"@en ;
  sbsp:profileClass "SpringStrip" ;
  sbsp:thickness "1.00"^^xsd:decimal ;
  sbsp:width "10.0"^^xsd:decimal ;
  sbsp:length "150.0"^^xsd:decimal .
