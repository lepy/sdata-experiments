@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix voc: <https://w3id.org/sdata/vocabularies/specimen-shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/sdata/vocabularies/specimen-shapes/>
  a owl:Ontology ;
  owl:imports <https://w3id.org/sdata/core/> .

voc:ConceptScheme a skos:ConceptScheme ;
  skos:prefLabel "Specimen shapes"@en .

voc:FlatTensileSpecimenProfiles a skos:ConceptScheme ;
  skos:prefLabel "Flat tensile specimen profiles"@en .

voc:flat a skos:Concept ;
  skos:inScheme voc:ConceptScheme ;
  skos:prefLabel "flat"@en .

voc:round a skos:Concept ;
  skos:inScheme voc:ConceptScheme ;
  skos:prefLabel "round"@en .

voc:tubular a skos:Concept ;
  skos:inScheme voc:ConceptScheme ;
  skos:prefLabel "tubular"@en .

voc:hexa a skos:Concept ;
  skos:inScheme voc:ConceptScheme ;
  skos:prefLabel "hexa"@en .

voc:profileClass a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:string ;
  rdfs:label "profile class"@en .

voc:w a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "parallel width w"@en .

voc:t a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "thickness t"@en .

voc:l0 a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "original gauge length l0"@en .

voc:W a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "grip section width W"@en .

voc:l2 a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "transition length l2"@en .

voc:lg a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "grip length lg"@en .

voc:l1 a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "parallel length l1"@en .

voc:lt a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "total length lt"@en .

voc:r a owl:DatatypeProperty ;
  rdfs:domain skos:Concept ;
  rdfs:range xsd:decimal ;
  qudt:unit unit:MilliM ;
  rdfs:label "transition radius r"@en .


